---
import createTask from "../components/pages/Create.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Basics</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --cc-font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial,
      sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: clamp(14px, 1.4vw, 18px);
  }

  html,
  body {
    font-family: var(--cc-font-family);
    background-color: #630f8e;
    margin: 0;
    min-height: 100vh;
    width: 100%;
  }

  body {
    padding: clamp(16px, 3vw, 28px);
  }

  #create-task-form {
    display: block;
    width: min(100%, 720px);
    max-width: 100%;
    margin: 0 auto;
    background-color: #202020;
    box-sizing: border-box;
    padding: clamp(20px, 4vw, 36px);
    border-radius: clamp(12px, 2vw, 20px);
  }

  .create-title {
    display: inline-block;
    margin: 0 0 clamp(14px, 2vw, 20px) 0;
    padding: clamp(10px, 2vw, 16px) clamp(16px, 3vw, 20px);
    color: #32ffb8;
    background: rgba(50, 255, 184, 0.08);
    border: 2px solid #32ffb8;
    border-radius: clamp(12px, 2vw, 20px);
    font-size: clamp(24px, 4vw, 34px);
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.25);
  }

  .textarea {
    background-color: transparent;
    width: 100%;
    padding: 0;
    box-sizing: border-box;
    margin-bottom: clamp(12px, 2vw, 18px);
  }

  .textarea input,
  .textarea textarea,
  select {
    background-color: #1a1a1a;
    color: #fff;
    border: 1px solid #404040;
    padding: clamp(12px, 2vw, 18px);
    border-radius: clamp(8px, 1.5vw, 14px);
    width: 100%;
    box-sizing: border-box;
    font-family: var(--cc-font-family);
    font-size: clamp(15px, 1.5vw, 18px);
  }

  .textarea input::placeholder,
  .textarea textarea::placeholder {
    color: #999;
  }

  .textarea textarea {
    min-height: clamp(100px, 20vw, 160px);
    resize: vertical;
  }

  select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, #fff 50%),
      linear-gradient(135deg, #fff 50%, transparent 50%);
    background-position:
      calc(100% - 18px) calc(1em + 2px),
      calc(100% - 12px) calc(1em + 2px);
    background-size:
      8px 8px,
      8px 8px;
    background-repeat: no-repeat;
    padding-right: clamp(36px, 8vw, 48px);
  }

  select option {
    background-color: #202020;
    color: #fff;
  }

  button {
    background-color: #36f2aa;
    color: #101010;
    border: none;
    padding: clamp(12px, 2vw, 18px) clamp(20px, 4vw, 26px);
    border-radius: clamp(8px, 1.5vw, 14px);
    font-family: var(--cc-font-family);
    font-size: clamp(15px, 1.5vw, 18px);
    font-weight: bolder;
    cursor: pointer;
    width: 100%;
  }

  button:hover {
    background-color: #fd3e81;
    color: #fff;
  }
</style>
