import Navbar from "../components/pages/navbar.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Todo List</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --cc-font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial,
      sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: clamp(14px, 1.4vw, 18px);
  }

  h1 {
    display: block;
    text-align: center;
    padding: clamp(10px, 2vw, 16px) clamp(16px, 3vw, 20px);
    color: #f5ff32;
    background: rgba(245, 255, 50, 0.08);
    border: 2px solid #f5ff32;
    border-radius: clamp(12px, 2vw, 20px);
    font-size: clamp(24px, 4vw, 34px);
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.25);
    width: fit-content;
  }

  html,
  body {
    font-family: var(--cc-font-family);
    background-color: #630f8e;
    margin: 0;
    min-height: 100px;
    width: 100%;
  }

  button {
    background-color: #36f2aa;
    color: #101010;
    border: none;
    padding: clamp(12px, 2vw, 18px) clamp(20px, 4vw, 26px);
    border-radius: clamp(8px, 1.5vw, 14px);
    font-family: var(--cc-font-family);
    font-size: clamp(15px, 1.5vw, 18px);
    font-weight: bolder;
    cursor: pointer;
  }
  button:hover {
    background-color: #fd3e81;
    color: #fff;
  }
  ul {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  li {
  background-color: #202020;
  color: #fff;

  padding: 10px;
  border-radius: 10px;

  max-width: none; /* belangrijk: anders breekt je grid */
}
@media (max-width: 900px) {
  ul {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  ul {
    grid-template-columns: 1fr;
  }
}
