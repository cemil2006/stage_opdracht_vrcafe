---
import tasks from "../data/tasks.json";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>todo</title>
  </head>
  <body>
    <slot />
  </body>

  <section>
    <h1>Todo</h1>
  </section>

  <section>
    <ul>
      {
        tasks.map((task) => (
          <li>
            <h2>{task.titel}</h2>
            <p>{task.categorie}</p>
            <p>{task.beschrijving}</p>
          </li>
        ))
      }
    </ul>
    <ul>
      <li>
        <script>
          //haal local storage data op
          let tasks = JSON.parse(localStorage.getItem("tasks")) || [
            {
              titel: "titel",
              categorie: "categorie",
              beschrijving:
                "beschrijving",
            },
          ];
          //toon taken in console
          console.log(tasks);
        </script>
      </li>
    </ul>
  </section>
</html>
