---
import tasks from "../data/tasks.json";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>todo</title>
  </head>
  <body>
    <slot />
  </body>

  <section>
    <h1>Todo</h1>
    <a href="/create">Maak nieuwe taak</a>
    <ul id="local-tasks-list"></ul>

    <script>
      function showLocalStorageTasks() {
        // Haal de string met taken op uit localStorage
        const raw = localStorage.getItem("tasks");

        // Als er data is, parse JSON naar een JavaScript-array
        // Anders gebruik de taken uit de JSON of een standaard voorbeeldtaak
        const localTasks = raw
          ? JSON.parse(raw)
          : [
              {
                titel: "titel",
                categorie: "categorie",
                afgerond: false,
                beschrijving: "beschrijving",
              },
            ];

        // Zoek het <ul>-element waar we de taken willen tonen
        const list = document.getElementById("local-tasks-list");

        // Maak de lijst eerst leeg zodat we niet dubbel tonen
        list.innerHTML = "";

        // Loop door alle taken en voeg ze toe aan de lijst
        localTasks.forEach((task, index) => {
          const item = document.createElement("li");
          item.innerHTML = `
          <h2>${task.titel}</h2>
          <p>${task.categorie}</p>
          <p>${task.afgerond ? "Afgerond" : "Niet afgerond"}</p>
          <p>${task.beschrijving}</p>
        `.trim();

          const completeButton = document.createElement("button");
          completeButton.type = "button";
          completeButton.textContent = task.afgerond ? "Niet afgerond" : "Voltooid";
          completeButton.addEventListener("click", () => {
            const tasks = JSON.parse(localStorage.getItem("tasks")) || [];
            tasks[index].afgerond = !tasks[index].afgerond;
            localStorage.setItem("tasks", JSON.stringify(tasks));
            showLocalStorageTasks();
          });

          const deleteTask = (taskIndex) => {
            const tasks = JSON.parse(localStorage.getItem("tasks")) || [];
            tasks.splice(taskIndex, 1);
            localStorage.setItem("tasks", JSON.stringify(tasks));
            showLocalStorageTasks();
          };

          const deleteButton = document.createElement("button");
          deleteButton.type = "button";
          deleteButton.textContent = "Verwijder";
          deleteButton.addEventListener("click", () => deleteTask(index));

          item.appendChild(completeButton);
          item.appendChild(deleteButton);
          list.appendChild(item);
        });

        // Laat de taken ook in de browserconsole zien voor debugging
        console.log("Local storage taken:", localTasks);
      }

      // Roep de functie aan zodra de pagina is geladen
      document.addEventListener("DOMContentLoaded", showLocalStorageTasks);
    </script>
  </section>

  <section></section>
</html>
