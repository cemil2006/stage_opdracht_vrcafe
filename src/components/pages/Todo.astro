<section>
  <h1>Todo</h1>

  <select id="category-filter">
    <option value="">Alle categorieën</option>
  </select>

  <ul id="local-tasks-list"></ul>

  <script>

    function showtasks() {
      const tasks = JSON.parse(localStorage.getItem("tasks")) || [];
      console.log(tasks);
    }
    function renderFilter() {
      const tasks = JSON.parse(localStorage.getItem("tasks")) || [];

      const categories = [...new Set(tasks.map(task => task.categorie))];

      const select = document.getElementById("category-filter");

      select.innerHTML = `
        <option value="">Alle categorieën</option>
      `;

      categories.forEach(category => {
        const option = document.createElement("option");
        option.value = category;
        option.textContent = category;
        select.appendChild(option);
      });
    }

    function showLocalStorageTasks() {
      const tasks = JSON.parse(localStorage.getItem("tasks")) || [];

      const selectedCategory =
        document.getElementById("category-filter").value;

      const filteredTasks = selectedCategory
        ? tasks.filter(task => task.categorie === selectedCategory)
        : tasks;

      const list = document.getElementById("local-tasks-list");
      list.innerHTML = "";

      filteredTasks.forEach((task) => {
        const originalIndex = tasks.indexOf(task);

        const item = document.createElement("li");

        item.innerHTML = `
          <h2>${task.titel}</h2>
          <p>Categorie: ${task.categorie}</p>
          <p>Status: ${task.afgerond ? "Afgerond" : "Niet afgerond"}</p>
          <p>${task.beschrijving}</p>
        `;

        // Voltooien knop
        const completeButton = document.createElement("button");
        completeButton.textContent = task.afgerond
          ? "Niet afgerond"
          : "Voltooid";

        completeButton.addEventListener("click", () => {
          const allTasks =
            JSON.parse(localStorage.getItem("tasks")) || [];

          allTasks[originalIndex].afgerond =
            !allTasks[originalIndex].afgerond;

          localStorage.setItem(
            "tasks",
            JSON.stringify(allTasks)
          );

          showLocalStorageTasks();
        });

        // Verwijderen knop
        const deleteButton = document.createElement("button");
        deleteButton.textContent = "Verwijder";

        deleteButton.addEventListener("click", () => {
          const allTasks =
            JSON.parse(localStorage.getItem("tasks")) || [];

          allTasks.splice(originalIndex, 1);

          localStorage.setItem(
            "tasks",
            JSON.stringify(allTasks)
          );

          renderFilter();
          showLocalStorageTasks();
        });

        item.appendChild(completeButton);
        item.appendChild(deleteButton);

        list.appendChild(item);
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      renderFilter();
      showLocalStorageTasks();

      document
        .getElementById("category-filter")
        .addEventListener("change", showLocalStorageTasks);
    });
  </script>
</section>