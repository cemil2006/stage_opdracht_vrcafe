<section>
  <h2 class="create-title">Voeg een taak toe</h2>
  <form id="create-task-form">
    <div class="create-folder">
      <div class="textarea">
        <input
          id="titel"
          type="text"
          name="titel"
          placeholder="Voer de titel in"
          required
        />
      </div>

      <div class="create-dropdown">
        <select id="categorie" name="categorie" required>
          <option value="" disabled selected>Kies een categorie</option>
          <option value="persoonlijk">Persoonlijk</option>
          <option value="werk">Werk</option>
          <option value="vrije tijd">Vrije tijd</option>
        </select>
      </div>

      <div class="textarea">
        <input
          id="beschrijving"
          type="text"
          name="beschrijving"
          placeholder="Voer de beschrijving in"
          required
        />
      </div>
    </div>
    <button type="submit">Toevoegen</button>
  </form>
</section>

<script>
  // Deze functie regelt het hele formulier
  function setupForm() {
    const form = document.getElementById("create-task-form");
    
    // Beveiliging 1: Stop als het formulier niet op deze pagina staat
    if (!form) return; 

    // Beveiliging 2: Voorkom dat de listener er twee keer op wordt gezet
    if (form.getAttribute('data-has-listener') === 'true') return;
    form.setAttribute('data-has-listener', 'true');

    form.addEventListener("submit", function (e) {
      e.preventDefault(); // Stopt de traditionele 404-refresh

      // Waarden ophalen uit de inputs
      const titel = (document.getElementById("titel") as HTMLInputElement || document.getElementById("titel")).value;
      const categorie = (document.getElementById("categorie") as HTMLSelectElement || document.getElementById("categorie")).value;
      const afgerond = false;
      const beschrijving = (document.getElementById("beschrijving") as HTMLInputElement || document.getElementById("beschrijving")).value;

      // Haal bestaande taken op uit LocalStorage
      let tasks = [];
      try {
        tasks = JSON.parse(localStorage.getItem("tasks") || "[]");
      } catch (err) {
        tasks = [];
      }

      // Voeg nieuwe taak toe
      tasks.push({ titel, categorie, afgerond, beschrijving });

      // Sla alles op
      localStorage.setItem("tasks", JSON.stringify(tasks));
      
      // Geef een seintje aan de homepage dat er een nieuwe taak is
      window.dispatchEvent(new Event("tasks-updated"));

      // Reset het formulier
      this.reset();

      alert("Taak succesvol toegevoegd!");

      // Stuur de gebruiker terug naar de live homepage
      window.location.href = "/stage_opdracht_vrcafe/";
    });
  }

  // Zorg dat de functie direct start als de pagina laadt
  setupForm();

  // Zorg dat de functie OOK start als Astro van pagina wisselt (voor de zekerheid)
  document.addEventListener("astro:page-load", setupForm);
</script>