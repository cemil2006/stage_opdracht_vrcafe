<section>
  <h2 class="create-title">Voeg een taak toe</h2>
  <form id="create-task-form">
    <div class="create-folder">
      <div class="textarea">
        <input
          id="titel"
          type="text"
          name="titel"
          placeholder="Voer de titel in"
          required
        />
      </div>

      <div class="create-dropdown">
        <select id="categorie" name="categorie" required>
          <option value="" disabled selected>Kies een categorie</option>
          <option value="persoonlijk">Persoonlijk</option>
          <option value="werk">Werk</option>
          <option value="vrije tijd">Vrije tijd</option>
        </select>
      </div>

      <div class="textarea">
        <input
          id="beschrijving"
          type="text"
          name="beschrijving"
          placeholder="Voer de beschrijving in"
          required
        />
      </div>
    </div>
    <button type="submit">Toevoegen</button>
  </form>
</section>

<script>
  // Luister naar de Astro lifecycle. Dit dekt de eerste keer laden EN pagina-wissels.
  document.addEventListener("astro:page-load", setupForm);

  function setupForm() {
    const form = document.getElementById("create-task-form");
    
    // Beveiliging 1: Stop als het formulier niet op deze pagina staat
    if (!form) return; 

    // Beveiliging 2: Stop als er al een luisteraar op dit formulier zit
    if (form.dataset.hasListener === "true") return;
    form.dataset.hasListener = "true";

    form.addEventListener("submit", function (e) {
      e.preventDefault(); // Stopt het traditionele verzenden (voorkomt 404)

      // Waarden ophalen uit de inputs
      const titel = (document.getElementById("titel") as HTMLInputElement).value;
      const categorie = (document.getElementById("categorie") as HTMLSelectElement).value;
      const afgerond = false;
      const beschrijving = (document.getElementById("beschrijving") as HTMLInputElement).value;

      // Haal bestaande taken op
      let tasks = JSON.parse(localStorage.getItem("tasks") || "[]");

      // Voeg nieuwe taak toe
      tasks.push({ titel, categorie, afgerond, beschrijving });

      // Sla alles op in LocalStorage
      localStorage.setItem("tasks", JSON.stringify(tasks));
      
      // Geef een seintje dat de taken zijn bijgewerkt
      window.dispatchEvent(new Event("tasks-updated"));

      // Reset het formulier direct
      this.reset();
      
      // Stuur de gebruiker netjes terug naar de homepage
      window.location.href = "/stage_opdracht_vrcafe/";
    });
  }
</script>