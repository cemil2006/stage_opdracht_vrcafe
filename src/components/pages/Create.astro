<section>
  <h2 class="create-title">Voeg een taak toe</h2>
  <form id="create-task-form">
    <div class="create-folder">
      <div class="textarea">
        <input
          id="titel"
          type="text"
          name="titel"
          placeholder="Voer de titel in"
          required
        />
      </div>

      <div class="create-dropdown">
        <select id="categorie" name="categorie" required>
          <option value="" disabled selected>Kies een categorie</option>
          <option value="persoonlijk">Persoonlijk</option>
          <option value="werk">Werk</option>
          <option value="vrije tijd">Vrije tijd</option>
        </select>
      </div>

      <div class="textarea">
        <input
          id="beschrijving"
          type="text"
          name="beschrijving"
          placeholder="Voer de beschrijving in"
          required
        />
      </div>
    </div>
    <button type="submit">Toevoegen</button>
  </form>
</section>

<script>
  // Astro gebruikt een eigen event-lifecycle. 
  // Dit zorgt ervoor dat het script ALTIJD werkt, ook na het switchen van pagina's.
  document.addEventListener("astro:page-load", setupForm) || setupForm();

  function setupForm() {
    const form = document.getElementById("create-task-form");
    if (!form) return; // Beveiliging: stop als het formulier niet op deze pagina staat

    // Verwijder oude listeners om dubbele triggers te voorkomen
    form.removeAttribute('data-has-listener'); 
    
    form.addEventListener("submit", function (e) {
      e.preventDefault(); // Dit stopt het traditionele verzenden (voorkomt de 404!)

      const titel = document.getElementById("titel").value;
      const categorie = document.getElementById("categorie").value;
      const afgerond = false; 
      const beschrijving = document.getElementById("beschrijving").value;

      // Haal bestaande taken op
      let tasks = JSON.parse(localStorage.getItem("tasks")) || [];

      // Voeg nieuwe taak toe
      tasks.push({ titel, categorie, afgerond, beschrijving });

      // Sla alles op in LocalStorage
      localStorage.setItem("tasks", JSON.stringify(tasks));
      window.dispatchEvent(new Event("tasks-updated"));

      // Reset formulier
      this.reset();

      alert("Taak toegevoegd!");

      // Stuur de gebruiker veilig terug naar de GitHub Pages homepage
      window.location.href = "/stage_opdracht_vrcafe/";
    });
  }

  // Voer direct uit bij de eerste keer laden
  setupForm();
</script>
